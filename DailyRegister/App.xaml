<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:DailyRegister.Helpers"
             x:Class="DailyRegister.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Merged dictionaries from default MAUI template -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Our custom converters -->
            <helpers:IsNotNullConverter x:Key="IsNotNullConverter" />
            <helpers:IsNotEmptyConverter x:Key="IsNotEmptyConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>