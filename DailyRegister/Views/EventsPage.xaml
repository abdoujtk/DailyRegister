<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DailyRegister.ViewModels"
             xmlns:models="clr-namespace:DailyRegister.Models"
             x:Class="DailyRegister.Views.EventsPage"
             x:DataType="viewmodels:EventsViewModel"
             Title="Daily Register">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <!-- Header -->
        <Button Grid.Row="0"
                Text="+ Add Event"
                Command="{Binding AddEventCommand}"
                HorizontalOptions="End"
                Margin="0,0,0,8" />

        <!-- Events List -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding Events}"
                         SelectionMode="None">

            <CollectionView.EmptyView>
                <Label Text="No events yet. Add your first event."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="Gray" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AppEvent">
                    <Border Padding="12" Margin="0,4"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource Primary}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}">

                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto" RowSpacing="4" ColumnSpacing="8">

                            <!-- Row 0: Type badge and Date -->
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                <Border Padding="6,2"
                                        StrokeShape="RoundRectangle 4"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource Primary}">
                                    <Label Text="{Binding Type}"
                                           FontSize="11"
                                           TextColor="White" />
                                </Border>
                                <Label Text="{Binding EventDate, StringFormat='{0:dd/MM/yyyy}'}"
                                       FontSize="13"
                                       TextColor="Gray"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Edit Button -->
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="Edit"
                                    FontSize="11"
                                    Padding="8,2"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EventsViewModel}}, Path=EditEventCommand}"
                                    CommandParameter="{Binding .}" />

                            <!-- Delete Button -->
                            <Button Grid.Row="0" Grid.Column="2"
                                    Text="Del"
                                    FontSize="11"
                                    Padding="8,2"
                                    BackgroundColor="Red"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EventsViewModel}}, Path=DeleteEventCommand}"
                                    CommandParameter="{Binding .}" />

                            <!-- Row 1: Description and Amount -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Description}"
                                   FontSize="14"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding Amount, StringFormat='{0:N2}'}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>