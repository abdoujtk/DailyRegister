<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DailyRegister.ViewModels"
             xmlns:models="clr-namespace:DailyRegister.Models"
             x:Class="DailyRegister.Views.AddEditEventPopup"
             x:DataType="viewmodels:AddEditEventViewModel"
             Title="Add Event">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="14">

            <Label Text="{Binding Title}" FontSize="20" FontAttributes="Bold" />

            <!-- Event Type Picker -->
            <Label Text="Type" />
            <Picker ItemsSource="{Binding EventTypes}"
                    SelectedItem="{Binding SelectedType}" />

            <!-- Contact Picker (hidden for general_note) -->
            <VerticalStackLayout Spacing="6" IsVisible="{Binding ShowContact}">
                <Label Text="Contact" />
                <Picker ItemsSource="{Binding Contacts}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedContact}"
                        Title="Select a contact" />
            </VerticalStackLayout>

            <!-- Amount (hidden for product_entry and general_note) -->
            <VerticalStackLayout Spacing="6" IsVisible="{Binding ShowAmount}">
                <Label Text="Amount" />
                <Entry Text="{Binding Amount}"
                       Placeholder="0.00"
                       Keyboard="Numeric" />
            </VerticalStackLayout>

            <!-- Description -->
            <Label Text="Description" />
            <Editor Text="{Binding Description}"
                    Placeholder="What happened?"
                    HeightRequest="100" />

            <!-- Date -->
            <Label Text="Date" />
            <DatePicker Date="{Binding EventDate}" />

            <!-- Buttons -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    Margin="0,10,0,0" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Gray" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>