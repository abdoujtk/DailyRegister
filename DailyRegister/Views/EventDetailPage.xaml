<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DailyRegister.ViewModels"
             x:Class="DailyRegister.Views.EventDetailPage"
             x:DataType="viewmodels:EventDetailViewModel"
             Title="Event Detail">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="14">

            <!-- Type Badge -->
            <Border Padding="10,4"
                    StrokeShape="RoundRectangle 6"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource Primary}"
                    HorizontalOptions="Start">
                <Label Text="{Binding AppEvent.Type}"
                       FontSize="14"
                       TextColor="White" />
            </Border>

            <!-- Contact -->
            <VerticalStackLayout Spacing="4" IsVisible="{Binding AppEvent.ContactId, Converter={StaticResource IsNotNullConverter}}">
                <Label Text="Contact" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding ContactName}" FontSize="16" />
            </VerticalStackLayout>

            <!-- Amount -->
            <VerticalStackLayout Spacing="4" IsVisible="{Binding AppEvent.Amount, Converter={StaticResource IsNotNullConverter}}">
                <Label Text="Amount" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding AppEvent.Amount, StringFormat='{0:N2}'}" FontSize="22" FontAttributes="Bold" />
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Description" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding AppEvent.Description}" FontSize="16" />
            </VerticalStackLayout>

            <!-- Date -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Date" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding AppEvent.EventDate, StringFormat='{0:dd/MM/yyyy}'}" FontSize="16" />
            </VerticalStackLayout>

            <!-- Created At -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Recorded At" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding AppEvent.CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="14" />
            </VerticalStackLayout>

            <!-- Status Note (if exists) -->
            <VerticalStackLayout Spacing="4" IsVisible="{Binding StatusNote, Converter={StaticResource IsNotEmptyConverter}}">
                <Label Text="Payment Note" FontSize="12" TextColor="Gray" />
                <Label Text="{Binding StatusNote}" FontSize="14" FontAttributes="Italic" />
            </VerticalStackLayout>

            <!-- Toggle Status Button (only for debts) -->
            <Button IsVisible="{Binding IsDebt}"
                    Margin="0,10,0,0"
                    Command="{Binding ToggleStatusCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsPaid}"
                                 Value="True">
                        <Setter Property="Text" Value="Mark as Unpaid" />
                        <Setter Property="BackgroundColor" Value="Orange" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsPaid}"
                                 Value="False">
                        <Setter Property="Text" Value="Mark as Paid" />
                        <Setter Property="BackgroundColor" Value="Green" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsTogglingStatus}"
                               IsVisible="{Binding IsTogglingStatus}"
                               Color="{StaticResource Primary}" />

            <!-- Back Button -->
            <Button Text="Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Gray"
                    Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>