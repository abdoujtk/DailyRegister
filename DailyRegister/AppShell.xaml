<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DailyRegister.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DailyRegister.Views">

    <TabBar>
        <ShellContent
            Title="Register"
            Icon="icon_events.png"
            ContentTemplate="{DataTemplate views:EventsPage}"
            Route="EventsPage" />

        <ShellContent
            Title="Contacts"
            Icon="icon_contacts.png"
            ContentTemplate="{DataTemplate views:ContactsPage}"
            Route="ContactsPage" />
    </TabBar>

</Shell>